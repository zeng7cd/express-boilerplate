# 测试环境配置
NODE_ENV=test
HOST=localhost
PORT=8081
CORS_ORIGIN=http://localhost:8081
API_PREFIX=api

# 测试数据库配置 - 使用内存数据库或测试专用数据库
DATABASE_URL="postgresql://test_user:test_password@localhost:5432/test_database?schema=public"

# 限流配置 - 测试环境放宽限制
COMMON_RATE_LIMIT_MAX_REQUESTS=10000
COMMON_RATE_LIMIT_WINDOW_MS=1000

# 日志配置 - 测试环境简化日志
LOGGER_LEVEL=error
LOG_TO_FILE=false
LOG_FILE_MAX_SIZE=10MB
LOG_FILE_MAX_FILES=10
LOG_CLEANUP_DAYS=30
LOG_HEALTH_CHECK_INTERVAL=60
LOG_PERFORMANCE_MONITORING=false

# Redis配置 - 测试环境
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=1

# JWT配置 - 测试环境使用固定密钥
JWT_SECRET=test-jwt-secret-key-for-testing-only-min-32-chars
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# 密码加密 - 测试环境使用最小轮数以提高速度
BCRYPT_ROUNDS=10

# 会话配置
SESSION_TIMEOUT=3600

# 监控配置 - 测试环境禁用
METRICS_ENABLED=false
HEALTH_CHECK_ENABLED=true
