# ============================================
# 测试环境配置
# ============================================
# 继承 .env 中的基础配置，只覆盖需要修改的值

# 应用配置
NODE_ENV=test
PORT=8081
CORS_ORIGIN=http://localhost:8081

# 测试数据库配置 - 使用测试专用数据库
DATABASE_URL="postgresql://test_user:test_password@localhost:5432/test_database?schema=public"

# 限流配置 - 测试环境放宽限制
COMMON_RATE_LIMIT_MAX_REQUESTS=10000

# 日志配置 - 测试环境简化日志
LOGGER_LEVEL=error
LOG_TO_FILE=false
LOG_FILE_MAX_SIZE=10MB
LOG_FILE_MAX_FILES=10
LOG_PERFORMANCE_MONITORING=false

# Redis配置 - 使用不同的数据库索引
REDIS_DB=1

# JWT配置 - 测试环境使用固定密钥
JWT_SECRET=test-jwt-secret-key-for-testing-only-min-64-chars-long-please-use-this
JWT_REFRESH_SECRET=test-refresh-secret-key-for-testing-only-min-64-chars-different

# 密码加密 - 测试环境使用最小轮数以提高速度
BCRYPT_ROUNDS=10

# 监控配置 - 测试环境禁用部分功能
METRICS_ENABLED=false
HEALTH_CHECK_ENABLED=true

# 安全配置
API_KEY=
ENABLE_CSRF_PROTECTION=false

# 功能开关
FEATURE_REGISTRATION_ENABLED=true
FEATURE_EMAIL_VERIFICATION=false
FEATURE_TWO_FACTOR_AUTH=false
