{
  "name": "express-typescript-boilerplate",
  "version": "0.0.1",
  "description": "An Express boilerplate backend",
  "author": "zeng",
  "repository": "express-typescript-2025",
  "main": "index.ts",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc && tsup",
    "start:dev": "cross-env NODE_ENV=development node --import=tsx --watch src/index.ts",
    "start:prod": "node dist/index.js",
    "format": "prettier --write .",
    "check": "eslint . --ext .ts,.tsx",
    "type-check": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx --fix",
    "lint:check": "eslint . --ext .ts,.tsx",
    "validate": "npm run type-check && npm run lint:check && npm run test",
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:migrate:prod": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.0.1",
    "@prisma/client": "^7.0.1",
    "bcryptjs": "^2.4.3",
    "chalk": "^5.6.2",
    "cors": "2.8.5",
    "cron": "^4.3.5",
    "cron-parser": "^5.4.0",
    "dayjs": "^1.11.19",
    "dotenv": "17.2.3",
    "express": "5.1.0",
    "express-rate-limit": "8.2.1",
    "helmet": "8.1.0",
    "http-status-codes": "2.3.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "nanoid": "^5.1.6",
    "pg": "^8.16.3",
    "pino": "10.1.0",
    "pino-http": "11.0.0",
    "prom-client": "^15.1.0",
    "radash": "^12.1.1",
    "rxjs": "^7.8.2",
    "ua-parser-js": "^2.0.6",
    "zod": "4.1.13"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "2.8.19",
    "@types/express": "5.0.5",
    "@types/ioredis": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^24.10.1",
    "@types/pg": "^8.15.6",
    "@types/supertest": "6.0.3",
    "@types/ua-parser-js": "^0.7.39",
    "@typescript-eslint/eslint-plugin": "^8.48.1",
    "@typescript-eslint/parser": "^8.48.1",
    "@vitest/coverage-v8": "4.0.14",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "globals": "^16.5.0",
    "pino-pretty": "13.1.2",
    "prettier": "^3.7.3",
    "prisma": "^7.0.1",
    "supertest": "7.1.4",
    "tsup": "8.5.1",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "vite-tsconfig-paths": "5.1.4",
    "vitest": "4.0.14"
  },
  "tsup": {
    "entry": [
      "src/index.ts"
    ],
    "outDir": "dist",
    "format": [
      "esm",
      "cjs"
    ],
    "target": "es2020",
    "sourcemap": true,
    "clean": true,
    "dts": true,
    "splitting": false,
    "skipNodeModulesBundle": true
  },
  "packageManager": "pnpm@10.12.1"
}
