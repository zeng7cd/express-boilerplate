{
  "name": "express-typescript-boilerplate",
  "version": "0.0.1",
  "description": "An Express boilerplate backend",
  "author": "zeng",
  "repository": "express-typescript-2025",
  "main": "index.ts",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc && tsup",
    "start:dev": "cross-env NODE_ENV=development node --import=tsx --watch src/index.ts",
    "start:prod": "node dist/index.js",
    "format": "prettier --write .",
    "check": "eslint . --ext .ts,.tsx",
    "type-check": "tsc --noEmit --skipLibCheck",
    "lint": "eslint . --ext .ts,.tsx --fix",
    "lint:check": "eslint . --ext .ts,.tsx",
    "validate": "npm run type-check && npm run lint:check && npm run test",
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "db:generate": "drizzle-kit generate",
    "db:push": "tsx src/core/database/migrate.ts",
    "db:migrate": "tsx src/core/database/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx src/core/database/seed.ts"
  },
  "dependencies": {
    "@paralleldrive/cuid2": "^3.0.4",
    "bcryptjs": "^3.0.3",
    "chalk": "^5.6.2",
    "cors": "2.8.5",
    "cron": "^4.4.0",
    "cron-parser": "^5.4.0",
    "dayjs": "^1.11.19",
    "dotenv": "17.2.3",
    "drizzle-orm": "^0.45.1",
    "express": "5.2.1",
    "express-rate-limit": "8.2.1",
    "helmet": "8.1.0",
    "http-status-codes": "2.3.0",
    "ioredis": "^5.8.2",
    "jsonwebtoken": "^9.0.3",
    "nanoid": "^5.1.6",
    "pg": "^8.16.3",
    "pino": "10.1.0",
    "pino-http": "11.0.0",
    "postgres": "^3.4.7",
    "prom-client": "^15.1.3",
    "radash": "^12.1.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "ua-parser-js": "^2.0.7",
    "zod": "4.1.13"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/cors": "2.8.19",
    "@types/express": "5.0.6",
    "@types/ioredis": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.0.1",
    "@types/pg": "^8.16.0",
    "@types/supertest": "6.0.3",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/ua-parser-js": "^0.7.39",
    "@typescript-eslint/eslint-plugin": "^8.49.0",
    "@typescript-eslint/parser": "^8.49.0",
    "@vitest/coverage-v8": "4.0.15",
    "cross-env": "^10.1.0",
    "drizzle-kit": "^0.31.8",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "globals": "^16.5.0",
    "pino-pretty": "13.1.3",
    "prettier": "^3.7.4",
    "supertest": "7.1.4",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "tsup": "8.5.1",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "vite-tsconfig-paths": "5.1.4",
    "vitest": "4.0.15"
  },
  "tsup": {
    "entry": [
      "src/index.ts"
    ],
    "outDir": "dist",
    "format": [
      "esm",
      "cjs"
    ],
    "target": "es2020",
    "sourcemap": true,
    "clean": true,
    "dts": true,
    "splitting": false,
    "skipNodeModulesBundle": true
  },
  "packageManager": "pnpm@10.12.1"
}
